# ══════════════════════════════════════════════
# ProposeAI — Переменные окружения (Vercel)
# Vercel Dashboard → Settings → Environment Variables
# ══════════════════════════════════════════════

# ── SUPABASE ────────────────────────────────
SUPABASE_URL=https://YOURPROJECT.supabase.co
SUPABASE_ANON_KEY=eyJhbGc...
SUPABASE_SERVICE_ROLE_KEY=eyJhbGc...

# ── ИИ МОДЕЛИ ───────────────────────────────
ANTHROPIC_API_KEY=sk-ant-api03-...
OPENAI_API_KEY=sk-proj-...
GOOGLE_AI_KEY=AIzaSy...

# ── YOOKASSA (российские карты) ─────────────
# Зарегистрироваться: https://yookassa.ru
# Нужен договор с ИП/ООО
YOOKASSA_SHOP_ID=123456
YOOKASSA_SECRET_KEY=test_...

# Stripe Price IDs для YooKassa тарифов (создать в YooKassa Dashboard)
# Для YooKassa используются YOOKASSA_SHOP_ID + YOOKASSA_SECRET_KEY

# ── NOWPAYMENTS (крипто) ─────────────────────
# Зарегистрироваться: https://nowpayments.io
NOWPAYMENTS_API_KEY=...
NOWPAYMENTS_IPN_SECRET=...

# ── STRIPE (международные карты) ─────────────
STRIPE_SECRET_KEY=sk_live_...
STRIPE_PRICE_STARTER=price_...
STRIPE_PRICE_PRO=price_...
STRIPE_PRICE_AGENCY=price_...
STRIPE_WEBHOOK_SECRET=whsec_...

# ── UPSTASH REDIS (rate limiting) ────────────
# Зарегистрироваться: https://upstash.com → создать Redis
UPSTASH_REDIS_REST_URL=https://...upstash.io
UPSTASH_REDIS_REST_TOKEN=...

# ── ПРИЛОЖЕНИЕ ───────────────────────────────
APP_URL=https://yourdomain.ru

# ── RESEND (транзакционная почта) ────────────────────────
# Зарегистрироваться: https://resend.com
RESEND_API_KEY=re_...
EMAIL_FROM=ProposeAI <noreply@yourdomain.ru>

# ── CRON ─────────────────────────────────────────────────
# Любая случайная строка для защиты cron эндпоинтов
CRON_SECRET=make-this-a-long-random-string-32-chars

# ── ADMIN ────────────────────────────────────────────────
# Любая длинная случайная строка — защита /api/admin и /api/invite
ADMIN_KEY=generate-long-random-key-here-min-32-chars

# ── SENTRY (мониторинг ошибок) ───────────────────────────
# Зарегистрироваться: https://sentry.io
SENTRY_DSN=https://xxx@oyyy.ingest.sentry.io/zzz

# ── ГОДОВЫЕ ТАРИФЫ STRIPE (добавить в Stripe Dashboard → Products) ──────
STRIPE_PRICE_STARTER_MONTHLY=price_...
STRIPE_PRICE_PRO_MONTHLY=price_...
STRIPE_PRICE_AGENCY_MONTHLY=price_...
STRIPE_PRICE_STARTER_ANNUAL=price_...
STRIPE_PRICE_PRO_ANNUAL=price_...
STRIPE_PRICE_AGENCY_ANNUAL=price_...

# Для обратной совместимости (старые имена перенаправляются автоматически)
# STRIPE_PRICE_STARTER = STRIPE_PRICE_STARTER_MONTHLY
# STRIPE_PRICE_PRO     = STRIPE_PRICE_PRO_MONTHLY
# STRIPE_PRICE_AGENCY  = STRIPE_PRICE_AGENCY_MONTHLY

# ── РЕФЕРАЛЬНАЯ ПРОГРАММА ────────────────────────────────
# Настраивается автоматически, дополнительных ключей не нужно
# Бонус: 7 дней к триалу рефераля + 30 дней к подписке реферера

# ── ЭКСПОРТ PDF ─────────────────────────────────────────
# PDF создаётся как print-optimised HTML (без Puppeteer)
# Открывается в браузере → Ctrl+P → Сохранить как PDF
# Для настоящего server-side PDF добавить @sparticuz/chromium
# и установить: AWS_LAMBDA_FUNCTION_NAME= (для Vercel Pro)

# ── PDF EXPORT (опционально, для Vercel Pro) ─────────────────
# npm install @sparticuz/chromium puppeteer-core
# Добавить в package.json dependencies
# Vercel Free tier: функция до 50MB — Chromium ~45MB, работает
# Если puppeteer недоступен — автоматически fallback на HTML

# ── A/B ТЕСТЫ (опционально) ──────────────────────────────────
# Не нужны отдельные ключи — используется та же Supabase
# Таблицы ab_events и analytics_events создаются через sql/schema.sql
